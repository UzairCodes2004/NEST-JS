generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model issue {
  id              Int          @id @default(autoincrement())
  title           String       @db.VarChar(255)
  description     String       @db.Text
  status          issue_status @default(OPEN)
  createdAT       DateTime     @default(now())
  updatedAT       DateTime
  userID          Int
  updatedByUserId Int?
  user            users        @relation(fields: [userID], references: [id])
  updatedByUser   users?       @relation("IssueUpdatedBy", fields: [updatedByUserId], references: [id])

  comments comment[]

  @@index([userID], map: "issue_userID_fkey")
}

model users {
  id            Int              @id @default(autoincrement())
  name          String           @db.VarChar(255)
  email         String           @unique(map: "Users_email_key")
  password      String?          @db.VarChar(255)
  registered    users_registered
  role          users_role       @default(USER)
  resetToken    String?
  tokenExpireAt DateTime?
  issues        issue[]

  editedIssues issue[] @relation("IssueUpdatedBy")

  comments comment[]
}

model comment {
  id        Int      @id @default(autoincrement())
  text      String   @db.Text
  createdAT DateTime @default(now())
  updatedAT DateTime @updatedAt

  userID Int
  user   users @relation(fields: [userID], references: [id])

  issueID Int
  issue   issue @relation(fields: [issueID], references: [id])
}

enum issue_status {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum users_registered {
  CREDENTIALS
  GOOGLE_OAUTH
}

enum users_role {
  SUPERADMIN
  USER
  MANAGER
}
